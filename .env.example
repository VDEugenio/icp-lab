# Copy to .env for local dev. On Railway, set these in the service Variables tab.
# NEVER commit the real .env — .gitignore covers it.

# Neon PostgreSQL connection string (same DB as outreach-backend)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Output of: python backend/hash_password.py
DASHBOARD_PASSWORD_HASH=pbkdf2_sha256$600000$...$...

# Long random string for signing session cookies, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# Prospect finder (JD → people). Same keys as OutreachAssistant.
ANTHROPIC_API_KEY=sk-ant-...
APOLLO_API_KEY=...

# Reply scanner (optional): auto-populates `responded` from LinkedIn
# "sent you a message" notification emails in Gmail. Read-only Gmail scope.
# Setup: Google Cloud Desktop-app OAuth client, then `python backend/gmail_auth.py`
# — full runbook in docs/operations.md. Leave unset to hide the feature.
# GMAIL_CLIENT_ID=....apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=...
# GMAIL_REFRESH_TOKEN=...

# Local dev only: allows the session cookie over plain http. Do NOT set on Railway.
# DEV_MODE=1
